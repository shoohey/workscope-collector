{
  "name": "base",
  "version": "1.0",
  "description": "全業界共通のPIIマスキング基盤プロファイル",
  "rules": [
    {
      "name": "email",
      "pattern": "[\\w.+-]+@[\\w-]+\\.[\\w.-]+",
      "category": "email",
      "context_keywords": [],
      "priority": 10
    },
    {
      "name": "my_number",
      "pattern": "(?<!\\d)\\d{4}[-\\s]?\\d{4}[-\\s]?\\d{4}(?!\\d)",
      "category": "my_number",
      "context_keywords": [],
      "priority": 20
    },
    {
      "name": "phone",
      "pattern": "0\\d{1,4}[-(]?\\d{1,4}[-)]?\\d{3,4}",
      "category": "phone",
      "context_keywords": [],
      "priority": 30
    },
    {
      "name": "name_kanji_honorific",
      "pattern": "[一-鿿々]{2,5}\\s?(?:様|さん|殿|氏)",
      "category": "personal_name",
      "context_keywords": [],
      "priority": 40
    },
    {
      "name": "name_kana_honorific",
      "pattern": "[゠-ヿぁ-ゟー]{2,10}\\s?(?:様|さん|殿|氏)",
      "category": "personal_name_kana",
      "context_keywords": [],
      "priority": 41
    },
    {
      "name": "name_kana_long",
      "pattern": "[゠-ヿ]{3,}[　\\s]?[゠-ヿ]{2,}",
      "category": "personal_name_kana",
      "context_keywords": [],
      "priority": 42
    },
    {
      "name": "date_wareki",
      "pattern": "(?:明治|大正|昭和|平成|令和)\\s?\\d{1,2}\\s?年\\s?\\d{1,2}\\s?月\\s?\\d{1,2}\\s?日",
      "category": "birthdate",
      "context_keywords": [],
      "priority": 50
    },
    {
      "name": "date_kanji",
      "pattern": "(?:19|20)\\d{2}\\s?年\\s?(?:0?[1-9]|1[0-2])\\s?月\\s?(?:0?[1-9]|[12]\\d|3[01])\\s?日",
      "category": "birthdate",
      "context_keywords": [],
      "priority": 51
    },
    {
      "name": "date_slash",
      "pattern": "(?:19|20)\\d{2}[\\-/.]\\s?(?:0?[1-9]|1[0-2])[\\-/.]\\s?(?:0?[1-9]|[12]\\d|3[01])",
      "category": "birthdate",
      "context_keywords": [],
      "priority": 52
    },
    {
      "name": "postal",
      "pattern": "(?<!\\d)〒?\\s?\\d{3}-?\\d{4}(?!\\d)",
      "category": "postal_code",
      "context_keywords": [],
      "priority": 60
    },
    {
      "name": "address",
      "pattern": "(?:北海道|青森県|岩手県|宮城県|秋田県|山形県|福島県|茨城県|栃木県|群馬県|埼玉県|千葉県|東京都|神奈川県|新潟県|富山県|石川県|福井県|山梨県|長野県|岐阜県|静岡県|愛知県|三重県|滋賀県|京都府|大阪府|兵庫県|奈良県|和歌山県|鳥取県|島根県|岡山県|広島県|山口県|徳島県|香川県|愛媛県|高知県|福岡県|佐賀県|長崎県|熊本県|大分県|宮崎県|鹿児島県|沖縄県)[一-鿿ぁ-ゟ゠-ヿ\\w]{1,30}?\\d+(?:-\\d+){0,3}",
      "category": "address",
      "context_keywords": [],
      "priority": 61
    }
  ],
  "whitelist": {}
}
