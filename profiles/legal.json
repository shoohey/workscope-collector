{
  "name": "legal",
  "extends": "base",
  "version": "1.0",
  "description": "法律事務所・弁護士・司法書士・行政書士向けマスキングプロファイル",
  "rules": [
    {
      "name": "case_number",
      "pattern": "(?:平成|令和)\\s?\\d{1,2}\\s?年\\s?\\(?[ワヨツヤノモ]\\)?第\\s?\\d{1,6}\\s?号",
      "category": "case_number",
      "context_keywords": [],
      "priority": 100
    },
    {
      "name": "case_number_simple",
      "pattern": "(?<!\\d)\\d{4,}号(?:事件)?",
      "category": "case_number",
      "context_keywords": ["事件番号", "案件番号", "受付番号"],
      "priority": 101
    },
    {
      "name": "court_name",
      "pattern": "(?:最高|高等|地方|簡易|家庭)裁判所",
      "category": "court_name",
      "context_keywords": [],
      "priority": 110
    },
    {
      "name": "company_with_prefix",
      "pattern": "(?:株式会社|有限会社|合同会社)[一-鿿ぁ-ゟ゠-ヿA-Za-z0-9]{2,30}",
      "category": "client_name",
      "context_keywords": [],
      "priority": 111
    },
    {
      "name": "client_company_name",
      "pattern": "[一-鿿ぁ-ゟ゠-ヿA-Za-z0-9]{2,30}(?:株式会社|有限会社|合同会社|合資会社|合名会社|\\(株\\)|\\(有\\))",
      "category": "client_name",
      "context_keywords": [],
      "priority": 112
    },
    {
      "name": "lawyer_registration",
      "pattern": "(?:弁護士|司法書士|行政書士|税理士|社労士|弁理士)登録番号\\s?第?\\s?\\d{4,7}\\s?号?",
      "category": "professional_id",
      "context_keywords": [],
      "priority": 120
    }
  ],
  "whitelist": {
    "legal_terms": [
      "民法", "刑法", "商法", "会社法", "民事訴訟法",
      "刑事訴訟法", "労働基準法", "独占禁止法",
      "原告", "被告", "控訴人", "被控訴人", "申立人"
    ]
  }
}
