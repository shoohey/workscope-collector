{
  "name": "real_estate",
  "extends": "base",
  "version": "1.0",
  "description": "不動産仲介・管理会社向けマスキングプロファイル",
  "rules": [
    {
      "name": "company_with_prefix",
      "pattern": "(?:株式会社|有限会社|合同会社)[一-鿿ぁ-ゟ゠-ヿA-Za-z0-9]{2,30}",
      "category": "customer_name",
      "context_keywords": [],
      "priority": 100
    },
    {
      "name": "property_id",
      "pattern": "\\d{4,}",
      "category": "property_id",
      "context_keywords": ["物件番号", "物件ID", "管理番号", "Reins番号"],
      "priority": 110
    },
    {
      "name": "rental_amount",
      "pattern": "[\\d,]+\\s?円(?:/月)?",
      "category": "rental_amount",
      "context_keywords": ["家賃", "賃料", "管理費", "共益費", "敷金", "礼金"],
      "priority": 120
    },
    {
      "name": "sale_price",
      "pattern": "[\\d,]+\\s?(?:円|万円|億円)",
      "category": "sale_price",
      "context_keywords": ["売出価格", "成約価格", "希望価格", "査定額"],
      "priority": 121
    },
    {
      "name": "license_realestate",
      "pattern": "(?:国土交通大臣|[都道府県]知事)\\s?\\(.*?\\)\\s?第\\s?\\d{3,7}\\s?号",
      "category": "license_id",
      "context_keywords": [],
      "priority": 130
    }
  ],
  "whitelist": {
    "real_estate_terms": [
      "媒介契約", "重要事項説明", "賃貸借契約", "売買契約",
      "仲介手数料", "成約", "募集中", "申込", "内見",
      "管理委託", "原状回復", "サブリース", "区分所有"
    ]
  }
}
